# Khi dev: địa chỉ backend để Vite proxy /api sang (giữ cookie first-party).
# Production do nginx lo, không cần biến này.
API_PROXY_TARGET=http://localhost:3000

# Optional: hiện nút chuyển về bản chính thức ở trang login demo/sandbox.
# Chỉ set ở sandbox/demo build, không set ở production chính.
VITE_OFFICIAL_URL=
VITE_OFFICIAL_LABEL=Dùng bản chính thức

# Optional: hiện khung tài khoản demo ở trang login.
# Chỉ set ở sandbox/demo build, không set ở production chính.
VITE_DEMO_EMAIL=
VITE_DEMO_PASSWORD=
VITE_DEMO_ROLE=Landlord demo
